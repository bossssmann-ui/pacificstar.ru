# Pacific Star — базовые настройки
Options -Indexes
DirectoryIndex index.html index.php

# ─── HTTPS редирект ────────────────────────────────────────────
# Перенаправление всех HTTP-запросов на HTTPS
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Разрешить доступ к файлам Let's Encrypt (ACME challenge)
    RewriteRule ^\.well-known/acme-challenge/ - [L]

    # Редирект HTTP → HTTPS
    RewriteCond %{HTTPS} !=on
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # Редирект www → без www (через HTTPS)
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
</IfModule>

# ─── Заголовки безопасности ────────────────────────────────────
<IfModule mod_headers.c>
    # HSTS — браузер будет запоминать, что сайт работает только через HTTPS
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

    # Защита от clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Защита от MIME-sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Отключить кэш для разработки
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</IfModule>
