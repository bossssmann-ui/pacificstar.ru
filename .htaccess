# Pacific Star — базовые настройки
Options -Indexes
DirectoryIndex index.html index.php

# 301 redirects for renamed pages
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^truck-delivery\.html$ /avto-dfo.html [R=301,L]
  RewriteRule ^remote-regions\.html$ /severnyy-zavoz.html [R=301,L]
</IfModule>

# Отключить кэш для разработки
<IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</IfModule>
