# Скопируйте в файл .env на компьютере, подставьте SMTP_PASS,
# загрузите в Timeweb: App Platform → приложение → Настройки →
# Настройка деплоя → Редактировать → Переменные → Загрузить из файла
#
# НЕ коммитьте реальный .env с паролем в git!

API_ONLY=true
CONTACT_EMAIL=sales@pacificstar.ru
CORS_ORIGIN=https://pacificstar.ru

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@pacificstar.ru
SMTP_PASS=ВСТАВЬТЕ_ПАРОЛЬ_ПРИЛОЖЕНИЯ_ЯНДЕКС
MAIL_FROM=Pacific Star <noreply@pacificstar.ru>
