# ── SMTP Configuration ──────────────────────────────────────────────
# Works with any SMTP provider: Yandex, Mail.ru, SendGrid, Gmail, etc.
#
# Yandex example:
#   SMTP_HOST=smtp.yandex.ru
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=noreply@pacificstar.ru
#   SMTP_PASS=your-app-password
#
# Mail.ru example:
#   SMTP_HOST=smtp.mail.ru
#   SMTP_PORT=465
#   SMTP_SECURE=true

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@pacificstar.ru
SMTP_PASS=

# ── Server ─────────────────────────────────────────────────────────
PORT=3000

# ── Email sender ───────────────────────────────────────────────────
MAIL_FROM="Pacific Star <noreply@pacificstar.ru>"

# ── Integrations ───────────────────────────────────────────────────
# Yandex Metrica counter ID — set in HTML as window.PS_YM_ID or inject at deploy
# PS_YM_ID=12345678

# AmoCRM incoming webhook URL (Settings → Integrations → Web hooks)
# AMOCRM_WEBHOOK_URL=https://your-subdomain.amocrm.ru/...

# ── Contact form delivery ───────────────────────────────────────────
# CONTACT_EMAIL=sales@pacificstar.ru
# CORS_ORIGIN=https://pacificstar.ru
# Frontend: set window.PS_API_BASE = 'https://api.pacificstar.ru' in js/config.js deploy override
