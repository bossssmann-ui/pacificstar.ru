# ── SMTP Configuration ──────────────────────────────────────────────
# Works with any SMTP provider: Yandex, Mail.ru, SendGrid, Gmail, etc.
#
# Yandex example:
#   SMTP_HOST=smtp.yandex.ru
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=noreply@pacificstar.ru
#   SMTP_PASS=your-app-password
#
# Mail.ru example:
#   SMTP_HOST=smtp.mail.ru
#   SMTP_PORT=465
#   SMTP_SECURE=true

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@pacificstar.ru
SMTP_PASS=

# ── Server ─────────────────────────────────────────────────────────
PORT=3000

# ── Email sender ───────────────────────────────────────────────────
MAIL_FROM="Pacific Star <noreply@pacificstar.ru>"
